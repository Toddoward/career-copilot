# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX_WORKS=cc_works
ES_SCHEMA_VERSION=1

# Redis
REDIS_URL=redis://localhost:6379/0

# SQLite
SQLITE_PATH=./data/career_copilot.db

# llama.cpp 서버 (로컬 직접 실행, Docker 외부)
LLAMA_CPP_URL=http://localhost:8080

# 모델 경로 (로컬 절대 경로로 변경)
MODEL_GROUP_A=./models/qwen2.5-7b-instruct-q4_k_m.gguf
MODEL_GROUP_C=./models/qwen2.5-vl-7b-q4_k_m.gguf
MODEL_BGE_M3=./models/bge-m3
MODEL_RERANKER=./models/bge-reranker-v2-m3

# VRAM 설정
GPU_LAYERS=35
FLASH_ATTN=true

# 생성 설정
MAX_RETRY_JUDGE=3
VRAM_SAFETY_MARGIN_GB=0.5